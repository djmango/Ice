<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Upstream Sparkle feed removed in this fork so official Ice releases
	     can never replace this build (auto-checks are also disabled in
	     UpdatesManager). To re-enable updates against a feed you control,
	     restore SUFeedURL + SUPublicEDKey. -->
	<key>SUEnableAutomaticChecks</key>
	<false/>
</dict>
</plist>
